{
  "name": "descall",
  "version": "1.0.0",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "server": "node src/server.js",
    "start": "electron .",
    "build": "vite build",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "jsonwebtoken": "^9.0.3",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.descall.app",
    "productName": "Descall",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
