{
  "name": "descall-electron",
  "version": "1.0.0",
  "description": "Descall - Discord-like chat application",
  "main": "main.cjs",
  "author": "Descall Team",
  "license": "MIT",
  "homepage": "https://descall-1.onrender.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/demirrsarppkurtlarr/descall.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "28.3.3",
    "electron-builder": "24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "electron-log": "^5.2.0"
  },
  "build": {
    "appId": "com.descall.app",
    "productName": "Descall",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "node_modules/**/*"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "../dist",
        "to": "dist",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "publisherName": "Descall",
      "icon": "../public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Descall",
      "artifactName": "Descall-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "Descall-Portable-${version}.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.social-networking",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "rpm",
          "arch": ["x64"]
        }
      ],
      "category": "Network",
      "maintainer": "Descall Team",
      "vendor": "Descall",
      "synopsis": "Discord-like chat application",
      "description": "Descall is a modern chat application with voice messaging, video calls, and group chats."
    }
  }
}
