{
  "name": "descall",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",

  "scripts": {
    "dev": "vite",
    "build": "vite build",

    "electron:dev": "electron .",
    "electron:start": "electron .",

    "electron:dist": "npm run build && electron-builder",
    "electron:pack": "npm run build && electron-builder --dir"
  },

  "engines": {
    "node": ">=20"
  },

  "dependencies": {
    "framer-motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.1",
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.4",
    "vite": "^5.4.10"
  },

  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.10",
    "electron": "^41.2.1",
    "electron-builder": "^24.13.3"
  },

  "build": {
    "appId": "com.descall.app",
    "productName": "Descall",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "backend/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "uninstallDisplayName": "Descall"
    },
    "asar": true
  }
}
