{
  "name": "descall",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",

  "scripts": {
    "dev": "vite",
    "build": "set VITE_API_BASE_URL=https://descall-qzkg.onrender.com && vite build",
    "preview": "vite preview",

    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:start": "electron .",
    "electron:build": "set VITE_API_BASE_URL=https://descall-qzkg.onrender.com && npm run build && electron-builder",
    "electron:build:win": "set VITE_API_BASE_URL=https://descall-qzkg.onrender.com && npm run build && electron-builder --win",
    "electron:build:mac": "set VITE_API_BASE_URL=https://descall-qzkg.onrender.com && npm run build && electron-builder --mac",
    "electron:build:linux": "set VITE_API_BASE_URL=https://descall-qzkg.onrender.com && npm run build && electron-builder --linux",
    "electron:pack": "npm run build && electron-builder --dir"
  },

  "engines": {
    "node": ">=20"
  },

  "dependencies": {
    "framer-motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.1",
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.4",
    "vite": "^5.4.10",
    "electron-updater": "^6.3.0",
    "electron-log": "^5.0.1"
  },

  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.10",
    "electron": "^41.2.1",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },

  "build": {
    "appId": "com.descall.app",
    "productName": "Descall",
    "copyright": "Copyright © 2024 Descall",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "backend/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "demirrsarppkurtlarr",
      "repo": "descall",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.social-networking",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "category": "Network",
      "maintainer": "Descall Team",
      "vendor": "Descall"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "uninstallDisplayName": "Descall",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Descall"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "asar": true,
    "asarUnpack": [
      "backend/**/*"
    ]
  }
}
